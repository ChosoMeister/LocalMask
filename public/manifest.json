{
  "manifest_version": 3,
  "name": "LocalMask - CDP Privacy Engine",
  "version": "1.0.2",
  "description": "Natively spoofs Timezone, Language, and Geolocation via CDP.",
  "permissions": [
    "debugger",
    "storage",
    "activeTab",
    "webNavigation",
    "privacy",
    "tabs"
  ],
  "host_permissions": [
    "https://ipwho.is/*"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "commands": {
    "toggle-mask": {
      "suggested_key": {
        "default": "Alt+Shift+X",
        "mac": "MacCtrl+Shift+X"
      },
      "description": "Toggle LocalMask ON/OFF"
    }
  }
}